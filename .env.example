# ========================================
# CONFIGURAÇÕES DO DISCORD
# ========================================
DISCORD_TOKEN=seu_token_do_discord_aqui
DISCORD_CLIENT_ID=seu_client_id_aqui
JBL_DISCORD_TOKEN=seu_token_do_bot_secundario_jbl_aqui

# ========================================
# CONFIGURAÇÕES DE TTS (VOZ PREDEFINIDA)
# ========================================
USE_VOICEBOX=false
VOICEBOX_ENGINE=qwen
VOICEBOX_MODEL_SIZE=0.6B
EDGETTS_VOICE=pt-BR-FranciscaNeural

# CONFIGURAÇÕES DE VOZ PREMIUM (FISH AUDIO API)
USE_FISH_AUDIO=true
FISH_API_KEY=sua_chave_fish_audio_aqui
FISH_VOICE_ID=seu_voice_id_fish_audio_aqui
FISH_MODEL=s2.1-pro-free
FISH_RPG_NARRATOR_VOICE_ID=seu_voice_id_narrador_rpg_aqui

# ========================================
# PROVIDER DE IA (GROQ)
# ========================================
AI_PROVIDER=groq
GROQ_API_KEY=sua_chave_groq_aqui
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# ========================================
# FALLBACK DE NUVEM (OPENROUTER) — grátis
# ========================================
# 2º provedor de nuvem, usado quando o Groq estoura o rate limit.
# Limite por REQUISIÇÃO (não por token): prompts grandes não penalizam.
# Cadeia final: Groq -> OpenRouter -> Ollama local.
# Pegue a key em https://openrouter.ai/keys
OPENROUTER_API_KEY=sua_chave_openrouter_aqui
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# Modelos free tentados em ordem (o OpenRouter rotaciona se um estiver congestionado).
# Máximo de 3 itens (limite do OpenRouter).
OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.5-flash:free,nvidia/nemotron-4-340b-instruct:free

# ========================================
# FALLBACK LOCAL (OLLAMA)
# ========================================
# Usado automaticamente quando o Groq estoura o rate limit (429/cota diária)
# e para mensagens simples/casuais — assim a cota do Groq dura muito mais.
# Requer o Ollama rodando localmente com os modelos abaixo baixados:
#   ollama pull qwen2.5:14b
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:14b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
# Mantém o modelo residente na VRAM (evita recarregar ~10GB a cada mensagem).
# -1 = nunca descarrega. Use "30m" para liberar a GPU após 30min ocioso.
OLLAMA_KEEP_ALIVE=-1

# ========================================
# CONFIGURAÇÕES DO REDIS
# ========================================
REDIS_URL=redis://localhost:6379

# ========================================
# APIS EXTERNAS
# ========================================
GOOGLE_API_KEY=sua_chave_do_google_custom_search_aqui
GOOGLE_CSE_ID=seu_id_do_google_custom_search_aqui
YOUTUBE_API_KEY=sua_chave_do_youtube_api_aqui
OPENWEATHERMAP_API_KEY=sua_chave_do_openweathermap_aqui
LASTFM_API_KEY=sua_chave_do_lastfm_aqui
GEONAMES_USERNAME=seu_usuario_do_geonames_aqui
OMDB_API_KEY=sua_chave_do_omdb_aqui

# ========================================
# CONFIGURAÇÕES DO PAINEL WEB
# ========================================
WEB_PORT=3000
SESSION_SECRET=mude_esse_segredo_em_producao_pelo_menos_32_caracteres
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SuaSenhaForteAqui123!

# ========================================
# CONFIGURAÇÕES DE MODERAÇÃO E COOLDOWN
# ========================================
MODERATION_ENABLED=true
MODERATION_THRESHOLD=0.7
IMAGE_COOLDOWN=30000
COMMAND_COOLDOWN=5000

# ========================================
# CONFIGURAÇÕES DE LIMITES E CUSTOS
# ========================================
MAX_TOKENS_PER_REQUEST=4000
MAX_COST_PER_REQUEST=0.10

# ========================================
# LAVALINK AUDIO SERVER
# ========================================
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# ========================================
# CONFIGURAÇÕES DE VOZ & BOT PROXY (VOICEBOX)
# ========================================
VOICEBOX_URL=http://localhost:17493
EXTERNAL_BOT_PREFIX=m!

# ========================================
# EMOJIS PERSONALIZADOS DO PLAYER
# ========================================
# Deixe em branco para usar os emojis padrão do bot (Unicode)
# Exemplo de ID de emoji personalizado: <:play:123456789012345678> ou animado <a:play:123456789012345678>
# EMOJI_PLAY=
# EMOJI_PAUSE=
# EMOJI_SKIP=
# EMOJI_STOP=
# EMOJI_VOL_DOWN=
# EMOJI_VOL_UP=
# EMOJI_LOOP=
# EMOJI_LOOP_TRACK=
# EMOJI_DJ=
# EMOJI_MUSIC=
